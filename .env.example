# Intercom Studio Chat Bridge - Environment Variables
# Copy this file to .env and fill in your values

# === Studio Chat ===
STUDIO_CHAT_API_KEY=your-api-key-here
# STUDIO_CHAT_BASE_URL=https://api.studiochat.io  # Optional, this is the default

# === Intercom ===
INTERCOM_ACCESS_TOKEN=your-intercom-access-token

# === Server ===
PORT=8080
HOST=0.0.0.0

# === Rollout ===
ROLLOUT_PERCENTAGE=100

# === Configuration ===
CONFIG_PATH=./config.yaml
